<!--
AutonomousFleet AI — NavigateToPose behaviour tree.

Tuned variant of the Nav2 "replanning with recovery" baseline for the MentorPi M1:

 - NavigateWithReplanning pipeline: rate-limited global planner + FollowPath.
   Replans at 1 Hz and is resilient to temporary planning failures (5 retries).
 - RecoveryFallback runs when the pipeline exhausts retries: clear both
   costmaps, rotate in place to refresh the local map, back up a short
   distance, then wait. Ordering is deliberately "cheapest recovery first" so
   the robot only physically moves when costmap clearing did not resolve the
   obstruction.
 - The root RecoveryNode retries the whole navigation 6 times before giving up,
   which keeps single transient failures from aborting a multi-waypoint mission.

Battery-guard hook: the `IsBatteryLow` condition node (plugin already loaded in
nav2_params.yaml) can be added once af_hal's battery status is republished on a
standard sensor_msgs/BatteryState topic. Left out of v1 to avoid a hard
dependency on Phase 5 work.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="1.0">
          <RecoveryNode number_of_retries="5" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            <ReactiveFallback name="ComputePathToPoseRecoveryFallback">
              <GoalUpdated/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Context"
                                  service_name="global_costmap/clear_entirely_global_costmap"/>
            </ReactiveFallback>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="FollowPath" goal_checker_id="general_goal_checker"/>
          <ReactiveFallback name="FollowPathRecoveryFallback">
            <GoalUpdated/>
            <ClearEntireCostmap name="ClearLocalCostmap-Context"
                                service_name="local_costmap/clear_entirely_local_costmap"/>
          </ReactiveFallback>
        </RecoveryNode>
      </PipelineSequence>

      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <RoundRobin name="RecoveryActions">
          <Sequence name="ClearingActions">
            <ClearEntireCostmap name="ClearLocalCostmap-Subtree"
                                service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-Subtree"
                                service_name="global_costmap/clear_entirely_global_costmap"/>
          </Sequence>
          <Spin spin_dist="1.57"/>
          <BackUp backup_dist="0.30" backup_speed="0.05"/>
          <Wait wait_duration="5"/>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
